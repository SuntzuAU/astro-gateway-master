---
import manifest from "../data/image-manifest.json";
import site from "../site.config.json";

const year = new Date().getFullYear();
const R2_BASE = import.meta.env.R2_PUBLIC_BASE || "";

function imgSrc(key) {
  const entry = manifest[key];
  if (!entry?.r2Key || !R2_BASE) return "";
  return `${R2_BASE.replace(/\/$/, "")}/${entry.r2Key}`;
}

function imgAlt(key) {
  return manifest[key]?.altText || key;
}

const c = site.colours;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.siteName} — {site.branding.headline}</title>
    <meta name="description" content={site.branding.subheadline} />
    <link rel="canonical" href={site.domain} />
    <style is:inline>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;background:#ffffff;color:#0f172a;line-height:1.6}
      a{color:inherit;text-decoration:none}
      img{max-width:100%;display:block}
      .wrap{max-width:1080px;margin:0 auto;padding:0 24px}

      /* NAV */
      header{position:sticky;top:0;background:rgba(255,255,255,.95);backdrop-filter:blur(12px);border-bottom:1px solid #e2e8f0;z-index:100}
      .nav{display:flex;align-items:center;justify-content:space-between;padding:12px 0;gap:16px}
      .logo{display:flex;align-items:center;gap:10px;font-weight:800;font-size:18px;color:#1a2f5e;letter-spacing:-0.02em}
      .logo img{height:44px;width:auto}
      .nav-links{display:flex;gap:20px;font-size:14px;font-weight:500;color:#334155}
      .nav-links a:hover{color:#1a2f5e}
      .nav-ctas{display:flex;gap:10px;align-items:center}

      /* BUTTONS */
      .btn{display:inline-block;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;border:2px solid transparent;cursor:pointer;transition:all .15s}
      .btn-primary{background:#f59e0b;border-color:#f59e0b;color:#0f172a}
      .btn-primary:hover{background:#d97706;border-color:#d97706}
      .btn-secondary{background:white;border-color:#cbd5e1;color:#1a2f5e}
      .btn-secondary:hover{border-color:#1a2f5e}
      .btn-lg{padding:14px 28px;font-size:16px;border-radius:10px}

      /* SECTIONS */
      section{padding:64px 0}
      .neutral-bg{background:#f1f5f9}
      .dark-bg{background:#1a2f5e;color:white}

      /* HERO */
      .hero{padding:80px 0 64px}
      .hero-inner{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
      .hero-pill{display:inline-flex;align-items:center;background:#f1f5f9;border:1px solid #e2e8f0;border-radius:999px;padding:6px 14px;font-size:13px;font-weight:600;color:#475569;margin-bottom:20px}
      .hero h1{font-size:44px;line-height:1.1;margin:0 0 16px;letter-spacing:-0.03em;color:#0f172a}
      .hero h1 span{color:#1a2f5e}
      .hero p{font-size:18px;color:#475569;margin:0 0 28px;max-width:520px}
      .hero-btns{display:flex;gap:12px;flex-wrap:wrap}
      .hero-img{border-radius:16px;overflow:hidden;aspect-ratio:16/9;background:#e2e8f0;box-shadow:0 20px 60px rgba(26,47,94,.15)}
      .hero-img img{width:100%;height:100%;object-fit:cover}
      .hero-placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#94a3b8;font-size:14px;background:#e2e8f0}

      /* TRUST BAR */
      .trust-bar{padding:20px 0;border-top:1px solid #e2e8f0;border-bottom:1px solid #e2e8f0}
      .trust-inner{display:flex;gap:32px;flex-wrap:wrap;align-items:center;justify-content:center}
      .trust-item{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:600;color:#475569}
      .trust-dot{width:8px;height:8px;border-radius:50%;background:#f59e0b;flex-shrink:0}

      /* CARDS */
      .cardgrid{display:grid;grid-template-columns:repeat(12,1fr);gap:16px}
      .card{grid-column:span 6;background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:24px}
      .card-img{border-radius:10px;overflow:hidden;aspect-ratio:16/9;background:#e2e8f0;margin-bottom:16px}
      .card-img img{width:100%;height:100%;object-fit:cover}
      .card h3{margin:0 0 8px;font-size:17px;color:#0f172a}
      .card p{margin:0;color:#475569;font-size:15px;line-height:1.6}
      .card-icon{font-size:28px;margin-bottom:12px}

      /* STEPS */
      .step-num{display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:50%;background:#f59e0b;color:#0f172a;font-weight:800;font-size:15px;margin-bottom:12px}

      /* SECTION HEADERS */
      .section-header{margin-bottom:36px}
      .section-header h2{font-size:32px;letter-spacing:-0.02em;margin:0 0 10px;color:#0f172a}
      .section-header p{font-size:17px;color:#475569;margin:0;max-width:600px}

      /* FORM AREA */
      .formbox{background:#fff;border:2px dashed #cbd5e1;border-radius:16px;padding:24px;min-height:340px;display:flex;flex-direction:column;justify-content:space-between}

      /* FOOTER */
      footer{background:#0f172a;color:#94a3b8;padding:28px 0;font-size:14px}
      .footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}
      .footer-links{display:flex;gap:20px}
      .footer-links a:hover{color:white}

      /* RESPONSIVE */
      @media(max-width:860px){
        .hero-inner{grid-template-columns:1fr}
        .hero h1{font-size:32px}
        .card{grid-column:span 12}
        .nav-links{display:none}
      }
      @media(max-width:500px){
        .hero-btns{flex-direction:column}
        .btn-lg{text-align:center}
      }
    </style>
  </head>
  <body>

    <header>
      <div class="wrap">
        <div class="nav">
          <div class="logo">
            <img src="/logo.png" alt={site.siteName} onerror="this.style.display='none'" />
          </div>
          <nav class="nav-links" aria-label="Primary">
            {site.navItems?.map((item) => <a href={item.url}>{item.label}</a>)}
          </nav>
          <div class="nav-ctas">
            {site.secondaryCTA?.text
              ? <a class="btn btn-secondary" href={site.secondaryCTA.url}>{site.secondaryCTA.text}</a>
              : null}
            <a class="btn btn-primary" href={site.primaryCTA.url}>{site.primaryCTA.text}</a>
          </div>
        </div>
      </div>
    </header>

    <main>

      <!-- HERO -->
      <section class="hero">
        <div class="wrap">
          <div class="hero-inner">
            <div>
              <div class="hero-pill">{site.branding.industry} • {site.branding.region}</div>
              <h1>{site.branding.headline}</h1>
              <p>{site.branding.subheadline}</p>
              <div class="hero-btns">
                <a class="btn btn-primary btn-lg" href={site.primaryCTA.url}>{site.primaryCTA.text}</a>
                {site.secondaryCTA?.text
                  ? <a class="btn btn-secondary btn-lg" href={site.secondaryCTA.url}>{site.secondaryCTA.text}</a>
                  : null}
              </div>
            </div>
            <div class="hero-img">
              {imgSrc("hero")
                ? <img src={imgSrc("hero")} alt={imgAlt("hero")} loading="eager" decoding="async" />
                : <div class="hero-placeholder">Hero image</div>
              }
            </div>
          </div>
        </div>
      </section>

      <!-- TRUST BAR -->
      <div class="trust-bar">
        <div class="wrap">
          <div class="trust-inner">
            {site.proofPoints?.map((p) => (
              <div class="trust-item">
                <div class="trust-dot"></div>
                {p}
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- BENEFITS -->
      <section id="benefits">
        <div class="wrap">
          <div class="section-header">
            <h2>Why Australian organisations choose Power PDF</h2>
            <p>Enterprise-grade PDF capability without the Adobe Acrobat price tag.</p>
          </div>
          <div class="cardgrid">
            {site.benefits?.map((b) => (
              <div class="card">
                <h3>{b.title}</h3>
                <p>{b.body}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ABOUT / PROOF -->
      <section id="proof" class="neutral-bg">
        <div class="wrap">
          <div class="cardgrid">
            <div class="card" style="grid-column:span 7">
              {imgSrc("about-banner")
                ? <div class="card-img"><img src={imgSrc("about-banner")} alt={imgAlt("about-banner")} loading="lazy" decoding="async" /></div>
                : null}
              <h3>Local expertise. Enterprise results.</h3>
              <p>Voice Recognition Australia has been deploying enterprise document software across Australian government, legal, and corporate environments for 25 years. We provide local onboarding, training, and ongoing support — not just a licence key.</p>
            </div>
            <div class="card" style="grid-column:span 5;background:#1a2f5e;color:white;border-color:#1a2f5e">
              <h3 style="color:white">Power PDF editions</h3>
              <div style="margin-top:16px;display:flex;flex-direction:column;gap:12px">
                <div style="background:rgba(255,255,255,.1);border-radius:10px;padding:14px">
                  <div style="font-weight:700;color:#f59e0b;margin-bottom:4px">Standard</div>
                  <div style="font-size:14px;color:#cbd5e1">Individual users — create, edit, convert, sign</div>
                </div>
                <div style="background:rgba(255,255,255,.1);border-radius:10px;padding:14px">
                  <div style="font-weight:700;color:#f59e0b;margin-bottom:4px">Advanced</div>
                  <div style="font-size:14px;color:#cbd5e1">Business users — redaction, collaboration, integrations</div>
                </div>
                <div style="background:rgba(255,255,255,.1);border-radius:10px;padding:14px">
                  <div style="font-weight:700;color:#f59e0b;margin-bottom:4px">Business SaaS</div>
                  <div style="font-size:14px;color:#cbd5e1">Enterprise volume — cloud editor, Teams, centralised management</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- HOW IT WORKS -->
      <section id="how-it-works">
        <div class="wrap">
          <div class="section-header">
            <h2>How it works</h2>
            <p>From enquiry to deployment — we handle everything locally.</p>
          </div>
          <div class="cardgrid">
            {site.steps?.map((s, i) => (
              <div class="card" style="grid-column:span 4">
                <div class="step-num">{i + 1}</div>
                <h3>{s.title}</h3>
                <p>{s.text}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- FEATURES WITH IMAGES -->
      <section id="features" class="neutral-bg">
        <div class="wrap">
          <div class="section-header">
            <h2>Key features</h2>
            <p>Everything your team needs to manage documents securely and efficiently.</p>
          </div>
          <div class="cardgrid">
            {site.features?.map((f) => (
              <div class="card" style="grid-column:span 6">
                {imgSrc(f.key)
                  ? <div class="card-img"><img src={imgSrc(f.key)} alt={imgAlt(f.key)} loading="lazy" decoding="async" /></div>
                  : null}
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section id="faq">
        <div class="wrap">
          <div class="section-header">
            <h2>Frequently asked questions</h2>
          </div>
          <div class="cardgrid">
            {site.faqs?.map((f) => (
              <div class="card">
                <h3>{f.q}</h3>
                <p>{f.a}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA / CONTACT -->
      <section id="final-cta" class="neutral-bg">
        <div class="wrap">
          <div class="section-header">
            <h2>Request information</h2>
            <p>Tell us about your requirements and we'll respond with tailored licensing options.</p>
          </div>
          <div class="cardgrid">
            <div class="card" style="grid-column:span 7">
              {imgSrc("cta-banner")
                ? <div class="card-img"><img src={imgSrc("cta-banner")} alt={imgAlt("cta-banner")} loading="lazy" decoding="async" /></div>
                : null}
              <h3>What to include in your enquiry</h3>
              <p style="color:#475569">The more detail you provide, the better we can tailor our response:</p>
              <ul style="color:#475569;margin:12px 0 0;padding-left:20px;line-height:2">
                <li>Organisation name and sector (government, legal, corporate)</li>
                <li>Number of users and deployment environment</li>
                <li>Current PDF solution and pain points</li>
                <li>Procurement requirements or constraints</li>
                <li>Timeline and budget range</li>
              </ul>
            </div>
            <div class="formbox" style="grid-column:span 5">
              <div>
                <div style="font-weight:700;font-size:18px;margin-bottom:8px;color:#0f172a">Get in touch</div>
                <div style="color:#475569;font-size:15px;margin-bottom:20px">We'll respond within one business day with options tailored to your environment.</div>
                <div style="color:#94a3b8;font-size:13px;background:#f8fafc;border-radius:10px;padding:16px;margin-bottom:20px">
                  Replace this box with your ActiveCampaign or HubSpot form embed code.
                </div>
              </div>
              <a class="btn btn-primary btn-lg" href="mailto:info@voicerecognition.com.au" style="text-align:center">
                {site.primaryCTA.text}
              </a>
            </div>
          </div>
        </div>
      </section>

    </main>

    <footer>
      <div class="wrap">
        <div class="footer-inner">
          <div>© {year} {site.siteName} — A Voice Recognition Australia service</div>
          <div class="footer-links">
            {site.footerLinks?.map((l) => <a href={l.url}>{l.label}</a>)}
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>
