---
import manifest from "../data/image-manifest.json";
import site from "../site.config.json";

const year = new Date().getFullYear();
const R2_BASE = import.meta.env.PUBLIC_R2_BASE || "";

function imgSrc(key) {
  const entry = manifest[key];
  if (!entry?.r2Key || !R2_BASE) return "";
  return `${R2_BASE.replace(/\/$/, "")}/${entry.r2Key}`;
}
function imgAlt(key) {
  return manifest[key]?.altText || key;
}

const c = site.colours;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.siteName} — {site.branding.headline}</title>
    <meta name="description" content={site.branding.subheadline} />
    <link rel="canonical" href={site.domain} />

    <!-- Google Analytics -->
    {site.googleAnalyticsId && (
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${site.googleAnalyticsId}`}></script>
      <script define:vars={{ gaId: site.googleAnalyticsId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    )}

    <style is:inline>
      :root {
        --color-primary: {c.primary};
        --color-background: {c.background};
        --color-neutral: {c.neutral};
        --color-accent: {c.accent};
        --color-accent-hover: {c.accentHover};
        --color-text: {c.text};
        --color-muted: {c.muted};
      }
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;background:var(--color-background);color:var(--color-text);line-height:1.6}
      a{color:inherit;text-decoration:none}
      img{max-width:100%;display:block}
      .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
      header{position:sticky;top:0;background:rgba(255,255,255,.96);backdrop-filter:blur(12px);border-bottom:1px solid #e2e8f0;z-index:100}
      .nav{display:flex;align-items:center;justify-content:space-between;padding:10px 0;gap:16px}
      .logo img{height:40px;width:auto}
      .nav-links{display:flex;gap:18px;font-size:14px;font-weight:500;color:#334155}
      .nav-links a:hover{color:var(--color-primary)}
      .nav-ctas{display:flex;gap:10px;align-items:center;flex-shrink:0}
      .btn{display:inline-block;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;border:2px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap}
      .btn-primary{background:var(--color-accent);border-color:var(--color-accent);color:var(--color-text)}
      .btn-primary:hover{background:var(--color-accent-hover);border-color:var(--color-accent-hover)}
      .btn-secondary{background:white;border-color:#cbd5e1;color:var(--color-primary)}
      .btn-secondary:hover{border-color:var(--color-primary)}
      .btn-lg{padding:14px 28px;font-size:16px;border-radius:10px}
      section{padding:64px 0}
      .neutral-bg{background:var(--color-neutral)}
      .dark-bg{background:var(--color-primary);color:white}
      .hero{padding:72px 0 56px}
      .hero-inner{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
      .hero-pill{display:inline-flex;align-items:center;background:#fef3c7;border:1px solid #fde68a;border-radius:999px;padding:6px 14px;font-size:13px;font-weight:600;color:#92400e;margin-bottom:18px}
      .hero h1{font-size:42px;line-height:1.1;margin:0 0 16px;letter-spacing:-0.03em}
      .hero p{font-size:17px;color:var(--color-muted);margin:0 0 28px;line-height:1.7}
      .hero-btns{display:flex;gap:12px;flex-wrap:wrap}
      .hero-img{border-radius:16px;overflow:hidden;aspect-ratio:16/9;background:#e2e8f0;box-shadow:0 24px 64px rgba(0,0,0,.18)}
      .hero-img img{width:100%;height:100%;object-fit:cover}
      .stats-bar{background:var(--color-primary);padding:13px 0}
      .stats-inner{display:flex;align-items:center;justify-content:center;gap:6px;flex-wrap:wrap}
      .stat-message{font-size:15px;font-weight:700;color:white;letter-spacing:0.01em;text-align:center}
      .stat-message span{color:var(--color-accent)}
      .video-section{padding:32px 0;background:var(--color-neutral)}
      .video-outer{max-width:800px;margin:0 auto}
      .yt-facade{position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:16px;box-shadow:0 24px 64px rgba(0,0,0,.15);cursor:pointer;background:#000}
      .yt-facade img{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;border-radius:16px;display:block}
      .yt-facade .yt-play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:68px;height:48px;background:#ff0000;border-radius:12px;display:flex;align-items:center;justify-content:center;transition:background .15s,transform .15s}
      .yt-facade:hover .yt-play{background:#cc0000;transform:translate(-50%,-50%) scale(1.08)}
      .yt-facade .yt-play svg{width:24px;height:24px;fill:white;margin-left:4px}
      .yt-facade iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:0;border-radius:16px}
      .sh{margin-bottom:40px}
      .sh h2{font-size:32px;letter-spacing:-0.02em;margin:0 0 10px}
      .sh p{font-size:17px;color:var(--color-muted);margin:0;max-width:600px}
      .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:16px}
      .c6{grid-column:span 6}
      .c4{grid-column:span 4}
      .c7{grid-column:span 7}
      .c5{grid-column:span 5}
      .card{background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:24px}
      .card-img{border-radius:10px;overflow:hidden;aspect-ratio:16/9;background:#e2e8f0;margin-bottom:16px}
      .card-img img{width:100%;height:100%;object-fit:cover}
      .card h3{margin:0 0 8px;font-size:17px}
      .card p{margin:0;color:var(--color-muted);font-size:15px;line-height:1.65}
      .benefit-card{background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:28px}
      .benefit-card h3{margin:8px 0 10px;font-size:18px}
      .benefit-card p{margin:0;color:var(--color-muted);font-size:15px;line-height:1.65}
      .card-icon{font-size:32px;margin-bottom:14px;line-height:1}
      .pricing-card{background:#fff;border:2px solid #e2e8f0;border-radius:20px;padding:28px;display:flex;flex-direction:column}
      .pricing-card.highlight{border-color:var(--color-accent);box-shadow:0 8px 32px rgba(0,0,0,.1)}
      .pricing-badge{display:inline-block;background:var(--color-accent);color:var(--color-text);font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px;margin-bottom:12px;text-transform:uppercase;letter-spacing:.05em}
      .pricing-name{font-size:20px;font-weight:700;margin:0 0 4px}
      .pricing-platform{font-size:13px;color:#64748b;margin:0 0 16px}
      .pricing-price{font-size:40px;font-weight:800;color:var(--color-primary);line-height:1;margin:0 0 4px}
      .pricing-note{font-size:13px;color:#64748b;margin:0 0 20px}
      .pricing-features{list-style:none;padding:0;margin:0 0 24px;flex:1}
      .pricing-features li{padding:7px 0;border-bottom:1px solid #f1f5f9;font-size:14px;color:#334155;display:flex;gap:8px;align-items:flex-start}
      .pricing-features li::before{content:"checkmark";color:var(--color-accent);font-weight:700;flex-shrink:0}
      .tco-table{width:100%;border-collapse:collapse;margin-top:24px}
      .tco-table th{text-align:left;padding:12px 16px;font-size:13px;font-weight:600;color:#475569;border-bottom:2px solid #e2e8f0;background:#f8fafc}
      .tco-table td{padding:14px 16px;font-size:15px;border-bottom:1px solid #f1f5f9}
      .tco-table tr.winner td{background:#fefce8;font-weight:700;color:var(--color-primary)}
      .tco-note{font-size:13px;color:#94a3b8;margin-top:12px}
      .step-num{display:inline-flex;align-items:center;justify-content:center;width:40px;height:40px;border-radius:50%;background:var(--color-accent);color:var(--color-text);font-weight:800;font-size:16px;margin-bottom:14px}
      .edition{background:rgba(255,255,255,.08);border-radius:12px;padding:16px;margin-bottom:10px}
      .edition-name{font-weight:700;color:var(--color-accent);margin-bottom:4px;font-size:15px}
      .edition-desc{font-size:14px;color:#cbd5e1;line-height:1.5}
      .formbox{background:#fff;border-radius:16px;padding:28px;display:flex;flex-direction:column;gap:16px}
      footer{background:#0f172a;color:#64748b;padding:28px 0;font-size:14px}
      .footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}
      .footer-links{display:flex;gap:20px}
      .footer-links a:hover{color:white}
      @media(max-width:900px){
        .hero-inner{grid-template-columns:1fr}
        .hero h1{font-size:30px}
        .c6,.c4,.c7,.c5{grid-column:span 12}
      }
    </style>
  </head>
  <body>

    <header>
      <div class="wrap">
        <div class="nav">
          <div class="logo">
            <img src="/logo.png" alt={site.siteName} onerror="this.style.display='none'" />
          </div>
          <nav class="nav-links" aria-label="Primary">
            {site.navItems?.map((item) => <a href={item.url}>{item.label}</a>)}
          </nav>
          <div class="nav-ctas">
            {site.secondaryCTA?.text && <a class="btn btn-secondary" href={site.secondaryCTA.url}>{site.secondaryCTA.text}</a>}
            <a class="btn btn-primary" href={site.primaryCTA.url}>{site.primaryCTA.text}</a>
          </div>
        </div>
      </div>
    </header>

    <main>

      <section class="hero">
        <div class="wrap">
          <div class="hero-inner">
            <div>
              <div class="hero-pill">⚡ {site.branding.industry} • {site.branding.region}</div>
              <h1>{site.branding.headline}</h1>
              <p>{site.branding.subheadline}</p>
              <div class="hero-btns">
                <a class="btn btn-primary btn-lg" href={site.primaryCTA.url}>{site.primaryCTA.text}</a>
                {site.secondaryCTA?.text && <a class="btn btn-secondary btn-lg" href={site.secondaryCTA.url}>{site.secondaryCTA.text}</a>}
              </div>
            </div>
            <div class="hero-img">
              {imgSrc("hero")
                ? <img src={imgSrc("hero")} alt={imgAlt("hero")} loading="eager" decoding="async" />
                : <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#94a3b8;font-size:14px">Hero image</div>
              }
            </div>
          </div>
        </div>
      </section>

      <div class="stats-bar">
        <div class="wrap">
          <div class="stats-inner">
            <div class="stat-message" set:html={site.branding.statsMessage.replace(/\b([\d%$A]+[^\s,]*)\b/g, '<span>$1</span>')} />
            <div style="display:flex;gap:20px;flex-wrap:wrap;justify-content:center;margin-top:4px">
              {site.stats?.map((s) => (
                <div style="font-size:13px;color:#94a3b8">checkmark <span style="color:white;font-weight:600">{s.value}</span> {s.label}</div>
              ))}
            </div>
          </div>
        </div>
      </div>

      {site.heroVideo?.enabled && (
        <section class="video-section">
          <div class="wrap">
            <div class="video-outer">
              <div class="yt-facade" data-ytid={site.heroVideo.youtubeId}>
                <img
                  src={`https://i.ytimg.com/vi/${site.heroVideo.youtubeId}/maxresdefault.jpg`}
                  alt="Play video"
                  loading="lazy"
                  decoding="async"
                />
                <div class="yt-play">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M8 5v14l11-7z"/></svg>
                </div>
              </div>
            </div>
            <script>
              document.querySelectorAll('.yt-facade').forEach(function(el) {
                el.addEventListener('click', function() {
                  var id = el.dataset.ytid;
                  var iframe = document.createElement('iframe');
                  iframe.src = 'https://www.youtube-nocookie.com/embed/' + id +
