---
import manifest from "../data/image-manifest.json";
import site from "../site.config.json";

const year = new Date().getFullYear();
const R2_BASE = import.meta.env.R2_PUBLIC_BASE || "";

function imgSrc(key) {
  const entry = manifest[key];
  if (!entry?.r2Key || !R2_BASE) return "";
  return `${R2_BASE.replace(/\/$/, "")}/${entry.r2Key}`;
}

function imgAlt(key) {
  return manifest[key]?.altText || key;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.siteName} — {site.branding.headline}</title>
    <meta name="description" content={site.branding.subheadline} />
    <link rel="canonical" href={site.domain} />
    <style is:inline>
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;background:#f8fafc;color:#0b1220;line-height:1.5}
      a{color:inherit}
      .wrap{max-width:1040px;margin:0 auto;padding:0 20px}
      header{position:sticky;top:0;background:rgba(255,255,255,.92);backdrop-filter:saturate(180%) blur(12px);border-bottom:1px solid #e7e7e7;z-index:10}
      .nav{display:flex;align-items:center;justify-content:space-between;padding:14px 0;gap:16px}
      .brand{font-weight:700;letter-spacing:-0.02em}
      .links{display:flex;gap:14px;flex-wrap:wrap;font-size:14px;color:#1f2937}
      .btn{display:inline-block;padding:10px 14px;border-radius:10px;text-decoration:none;font-weight:600;font-size:14px;border:1px solid #d1d5db}
      .btn-primary{background:#1e3a8a;border-color:#1e3a8a;color:white}
      .btn-secondary{background:white}
      section{padding:56px 0}
      .hero{padding:64px 0 44px}
      .hero-inner{display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:center}
      .hero h1{font-size:40px;line-height:1.1;margin:0 0 14px;letter-spacing:-0.03em}
      .hero p{max-width:520px;margin:0 0 22px;font-size:18px;color:#334155}
      .hero-img{border-radius:16px;overflow:hidden;aspect-ratio:16/9;background:#e2e8f0}
      .hero-img img{width:100%;height:100%;object-fit:cover;display:block}
      .cardgrid{display:grid;grid-template-columns:repeat(12,1fr);gap:14px}
      .card{grid-column:span 6;background:#fff;border:1px solid #e7e7e7;border-radius:16px;padding:18px}
      .card-img{border-radius:10px;overflow:hidden;aspect-ratio:16/9;background:#e2e8f0;margin-bottom:12px}
      .card-img img{width:100%;height:100%;object-fit:cover;display:block}
      @media(max-width:820px){
        .card{grid-column:span 12}
        .hero h1{font-size:32px}
        .hero-inner{grid-template-columns:1fr}
      }
      .muted{color:#475569}
      .pill{display:inline-flex;align-items:center;gap:8px;background:#eef2f7;border:1px solid #e7e7e7;border-radius:999px;padding:6px 10px;font-size:13px;color:#334155;margin-bottom:16px}
      .formbox{background:#fff;border:1px dashed #cbd5e1;border-radius:16px;padding:18px;min-height:320px}
      footer{border-top:1px solid #e7e7e7;padding:22px 0;color:#475569;font-size:14px}
      h2{font-size:26px;letter-spacing:-0.02em;margin:0 0 14px}
      h3{margin:0 0 8px}
      ul{margin:10px 0 0;padding-left:18px}
      .neutral-bg{background:#eef2f7}
    </style>
  </head>
  <body>

    <header>
      <div class="wrap">
        <div class="nav">
          <div class="brand">{site.siteName}</div>
          <nav class="links" aria-label="Primary">
            {site.navItems?.map((item) => <a href={item.url}>{item.label}</a>)}
          </nav>
          <div style="display:flex;gap:10px;align-items:center">
            {site.secondaryCTA?.text
              ? <a class="btn btn-secondary" href={site.secondaryCTA.url}>{site.secondaryCTA.text}</a>
              : null}
            <a class="btn btn-primary" href={site.primaryCTA.url}>{site.primaryCTA.text}</a>
          </div>
        </div>
      </div>
    </header>

    <main>

      <!-- HERO -->
      <section class="hero">
        <div class="wrap">
          <div class="hero-inner">
            <div>
              <div class="pill">{site.branding.industry} • {site.branding.region}</div>
              <h1>{site.branding.headline}</h1>
              <p>{site.branding.subheadline}</p>
              <div style="display:flex;gap:10px;flex-wrap:wrap">
                <a class="btn btn-primary" href={site.primaryCTA.url}>{site.primaryCTA.text}</a>
                {site.secondaryCTA?.text
                  ? <a class="btn btn-secondary" href={site.secondaryCTA.url}>{site.secondaryCTA.text}</a>
                  : null}
              </div>
            </div>
            <div class="hero-img">
              {imgSrc("hero")
                ? <img src={imgSrc("hero")} alt={imgAlt("hero")} loading="eager" decoding="async" />
                : <div style="width:100%;height:100%;background:#e2e8f0;display:flex;align-items:center;justify-content:center;color:#94a3b8;font-size:14px">Hero image</div>
              }
            </div>
          </div>
        </div>
      </section>

      <!-- BENEFITS -->
      <section id="benefits">
        <div class="wrap">
          <h2>Benefits</h2>
          <div class="cardgrid">
            {site.benefits?.map((b) => (
              <div class="card">
                <h3>{b}</h3>
                <p class="muted">We'll customise this copy per-site via config.</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- PROOF / TRUST -->
      <section id="proof" class="neutral-bg">
        <div class="wrap">
          <h2>Why choose us</h2>
          <div class="cardgrid">
            <div class="card" style="grid-column:span 7">
              {imgSrc("about-banner")
                ? <div class="card-img"><img src={imgSrc("about-banner")} alt={imgAlt("about-banner")} loading="lazy" decoding="async" /></div>
                : null}
              {site.proofPoints?.map((p) => (
                <div style="margin-bottom:10px">
                  <strong>{p}</strong>
                </div>
              ))}
            </div>
            <div class="card" style="grid-column:span 5">
              <h3>25+ years experience</h3>
              <p class="muted">Deep domain expertise in speech recognition and AI documentation tools for Australian enterprise and government.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- HOW IT WORKS -->
      <section id="how-it-works">
        <div class="wrap">
          <h2>How it works</h2>
          <div class="cardgrid">
            {site.steps?.map((s, i) => (
              <div class="card" style="grid-column:span 4">
                <div style="font-size:13px;font-weight:700;color:#1e3a8a;margin-bottom:6px">Step {i + 1}</div>
                <h3>{s.title}</h3>
                <p class="muted">{s.text}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- FEATURES WITH IMAGES -->
      <section id="features" class="neutral-bg">
        <div class="wrap">
          <h2>Key features</h2>
          <div class="cardgrid">
            <div class="card" style="grid-column:span 6">
              {imgSrc("feature-transcription")
                ? <div class="card-img"><img src={imgSrc("feature-transcription")} alt={imgAlt("feature-transcription")} loading="lazy" decoding="async" /></div>
                : null}
              <h3>Real-time transcription</h3>
              <p class="muted">AI-powered transcription that works in real time across clinical and professional environments.</p>
            </div>
            <div class="card" style="grid-column:span 6">
              {imgSrc("feature-multilingual")
                ? <div class="card-img"><img src={imgSrc("feature-multilingual")} alt={imgAlt("feature-multilingual")} loading="lazy" decoding="async" /></div>
                : null}
              <h3>57 languages supported</h3>
              <p class="muted">Multilingual speech recognition for diverse teams and international deployments.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section id="faq">
        <div class="wrap">
          <h2>Frequently asked questions</h2>
          <div class="cardgrid">
            {site.faqs?.map((f) => (
              <div class="card">
                <h3>{f.q}</h3>
                <p class="muted">{f.a}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA / CONTACT FORM -->
      <section id="final-cta" class="neutral-bg">
        <div class="wrap">
          <h2>Request information</h2>
          <div class="cardgrid">
            <div class="card" style="grid-column:span 7">
              {imgSrc("cta-banner")
                ? <div class="card-img"><img src={imgSrc("cta-banner")} alt={imgAlt("cta-banner")} loading="lazy" decoding="async" /></div>
                : null}
              <h3>Tell us what you need</h3>
              <p class="muted">Submit an enquiry with your requirements and we'll tailor our response to your environment.</p>
              <ul class="muted">
                <li>Name</li>
                <li>Email</li>
                <li>Phone</li>
                <li>Organisation</li>
                <li>Industry</li>
              </ul>
            </div>
            <div class="card formbox" style="grid-column:span 5">
              <div class="muted" style="font-weight:600;margin-bottom:8px">Contact form</div>
              <div class="muted">Replace this with your ActiveCampaign embed HTML.</div>
              <div style="margin-top:14px">
                <a class="btn btn-primary" href={site.primaryCTA.url}>{site.primaryCTA.text}</a>
              </div>
            </div>
          </div>
        </div>
      </section>

    </main>

    <footer>
      <div class="wrap" style="display:flex;justify-content:space-between;gap:14px;flex-wrap:wrap">
        <div>© {year} {site.siteName}</div>
        <div style="display:flex;gap:12px;flex-wrap:wrap">
          {site.footerLinks?.map((l) => <a href={l.url}>{l.label}</a>)}
        </div>
      </div>
    </footer>

  </body>
</html>
