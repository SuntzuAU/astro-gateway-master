---
import manifest from "../data/image-manifest.json";
import site from "../site.config.json";

const year = new Date().getFullYear();
const R2_BASE = import.meta.env.R2_PUBLIC_BASE || "";

function imgSrc(key) {
  const entry = manifest[key];
  if (!entry?.r2Key || !R2_BASE) return "";
  return `${R2_BASE.replace(/\/$/, "")}/${entry.r2Key}`;
}
function imgAlt(key) {
  return manifest[key]?.altText || key;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{site.siteName} — {site.branding.headline}</title>
    <meta name="description" content={site.branding.subheadline} />
    <link rel="canonical" href={site.domain} />
    <style is:inline>
      *,*::before,*::after{box-sizing:border-box}
      body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;background:#fff;color:#0f172a;line-height:1.6}
      a{color:inherit;text-decoration:none}
      img{max-width:100%;display:block}
      .wrap{max-width:1080px;margin:0 auto;padding:0 24px}
      header{position:sticky;top:0;background:rgba(255,255,255,.96);backdrop-filter:blur(12px);border-bottom:1px solid #e2e8f0;z-index:100}
      .nav{display:flex;align-items:center;justify-content:space-between;padding:10px 0;gap:16px}
      .logo img{height:40px;width:auto}
      .nav-links{display:flex;gap:18px;font-size:14px;font-weight:500;color:#334155}
      .nav-links a:hover{color:#1a2f5e}
      .nav-ctas{display:flex;gap:10px;align-items:center;flex-shrink:0}
      .btn{display:inline-block;padding:10px 20px;border-radius:8px;font-weight:700;font-size:14px;border:2px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap}
      .btn-primary{background:#f59e0b;border-color:#f59e0b;color:#0f172a}
      .btn-primary:hover{background:#d97706;border-color:#d97706}
      .btn-secondary{background:white;border-color:#cbd5e1;color:#1a2f5e}
      .btn-secondary:hover{border-color:#1a2f5e}
      .btn-lg{padding:14px 28px;font-size:16px;border-radius:10px}
      section{padding:64px 0}
      .neutral-bg{background:#f1f5f9}
      .dark-bg{background:#1a2f5e;color:white}
      .hero{padding:72px 0 56px}
      .hero-inner{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
      .hero-pill{display:inline-flex;align-items:center;background:#fef3c7;border:1px solid #fde68a;border-radius:999px;padding:6px 14px;font-size:13px;font-weight:600;color:#92400e;margin-bottom:18px}
      .hero h1{font-size:42px;line-height:1.1;margin:0 0 16px;letter-spacing:-0.03em}
      .hero p{font-size:17px;color:#475569;margin:0 0 28px;line-height:1.7}
      .hero-btns{display:flex;gap:12px;flex-wrap:wrap}
      .hero-img{border-radius:16px;overflow:hidden;aspect-ratio:16/9;background:#e2e8f0;box-shadow:0 24px 64px rgba(26,47,94,.18)}
      .hero-img img{width:100%;height:100%;object-fit:cover}

      /* STATS BAR — thin navy stripe */
      .stats-bar{background:#1a2f5e;padding:13px 0}
      .stats-inner{display:flex;align-items:center;justify-content:center;gap:6px;flex-wrap:wrap}
      .stat-message{font-size:15px;font-weight:700;color:white;letter-spacing:0.01em;text-align:center}
      .stat-message span{color:#f59e0b}
      .stat-dot{color:#475569;font-size:18px;line-height:1}

      .sh{margin-bottom:40px}
      .sh h2{font-size:32px;letter-spacing:-0.02em;margin:0 0 10px}
      .sh p{font-size:17px;color:#475569;margin:0;max-width:600px}
      .grid{display:grid;grid-template-columns:repeat(12,1fr);gap:16px}
      .c6{grid-column:span 6}
      .c4{grid-column:span 4}
      .c7{grid-column:span 7}
      .c5{grid-column:span 5}
      .card{background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:24px}
      .card-img{border-radius:10px;overflow:hidden;aspect-ratio:16/9;background:#e2e8f0;margin-bottom:16px}
      .card-img img{width:100%;height:100%;object-fit:cover}
      .card h3{margin:0 0 8px;font-size:17px}
      .card p{margin:0;color:#475569;font-size:15px;line-height:1.65}
      .benefit-card{background:#fff;border:1px solid #e2e8f0;border-radius:16px;padding:28px}
      .benefit-card h3{margin:8px 0 10px;font-size:18px}
      .benefit-card p{margin:0;color:#475569;font-size:15px;line-height:1.65}
      .card-icon{font-size:32px;margin-bottom:14px;line-height:1}
      .pricing-card{background:#fff;border:2px solid #e2e8f0;border-radius:20px;padding:28px;display:flex;flex-direction:column}
      .pricing-card.highlight{border-color:#f59e0b;box-shadow:0 8px 32px rgba(245,158,11,.2)}
      .pricing-badge{display:inline-block;background:#f59e0b;color:#0f172a;font-size:11px;font-weight:700;padding:4px 10px;border-radius:999px;margin-bottom:12px;text-transform:uppercase;letter-spacing:.05em}
      .pricing-name{font-size:20px;font-weight:700;margin:0 0 4px}
      .pricing-platform{font-size:13px;color:#64748b;margin:0 0 16px}
      .pricing-price{font-size:40px;font-weight:800;color:#1a2f5e;line-height:1;margin:0 0 4px}
      .pricing-note{font-size:13px;color:#64748b;margin:0 0 20px}
      .pricing-features{list-style:none;padding:0;margin:0 0 24px;flex:1}
      .pricing-features li{padding:7px 0;border-bottom:1px solid #f1f5f9;font-size:14px;color:#334155;display:flex;gap:8px;align-items:flex-start}
      .pricing-features li::before{content:"✓";color:#f59e0b;font-weight:700;flex-shrink:0}
      .tco-table{width:100%;border-collapse:collapse;margin-top:24px}
      .tco-table th{text-align:left;padding:12px 16px;font-size:13px;font-weight:600;color:#475569;border-bottom:2px solid #e2e8f0;background:#f8fafc}
      .tco-table td{padding:14px 16px;font-size:15px;border-bottom:1px solid #f1f5f9}
      .tco-table tr.winner td{background:#fefce8;font-weight:700;color:#1a2f5e}
      .tco-note{font-size:13px;color:#94a3b8;margin-top:12px}
      .step-num{display:inline-flex;align-items:center;justify-content:center;width:40px;height:40px;border-radius:50%;background:#f59e0b;color:#0f172a;font-weight:800;font-size:16px;margin-bottom:14px}
      .edition{background:rgba(255,255,255,.08);border-radius:12px;padding:16px;margin-bottom:10px}
      .edition-name{font-weight:700;color:#f59e0b;margin-bottom:4px;font-size:15px}
      .edition-desc{font-size:14px;color:#cbd5e1;line-height:1.5}
      .formbox{background:#fff;border-radius:16px;padding:28px;display:flex;flex-direction:column;gap:16px}
      footer{background:#0f172a;color:#64748b;padding:28px 0;font-size:14px}
      .footer-inner{display:flex;justify-content:space-between;gap:16px;flex-wrap:wrap;align-items:center}
      .footer-links{display:flex;gap:20px}
      .footer-links a:hover{color:white}
      @media(max-width:900px){
        .hero-inner{grid-template-columns:1fr}
        .hero h1{font-size:30px}
        .c6,.c4,.c7,.c5{grid-column:span 12}
      }
    </style>
  </head>
  <body>

    <header>
      <div class="wrap">
        <div class="nav">
          <div class="logo">
            <img src="/logo.png" alt={site.siteName} onerror="this.style.display='none'" />
          </div>
          <nav class="nav-links" aria-label="Primary">
            {site.navItems?.map((item) => <a href={item.url}>{item.label}</a>)}
          </nav>
          <div class="nav-ctas">
            {site.secondaryCTA?.text && <a class="btn btn-secondary" href={site.secondaryCTA.url}>{site.secondaryCTA.text}</a>}
            <a class="btn btn-primary" href={site.primaryCTA.url}>{site.primaryCTA.text}</a>
          </div>
        </div>
      </div>
    </header>

    <main>

      <section class="hero">
        <div class="wrap">
          <div class="hero-inner">
            <div>
              <div class="hero-pill">⚡ {site.branding.industry} • {site.branding.region}</div>
              <h1>{site.branding.headline}</h1>
              <p>{site.branding.subheadline}</p>
              <div class="hero-btns">
                <a class="btn btn-primary btn-lg" href={site.primaryCTA.url}>{site.primaryCTA.text}</a>
                {site.secondaryCTA?.text && <a class="btn btn-secondary btn-lg" href={site.secondaryCTA.url}>{site.secondaryCTA.text}</a>}
              </div>
            </div>
            <div class="hero-img">
              {imgSrc("hero")
                ? <img src={imgSrc("hero")} alt={imgAlt("hero")} loading="eager" decoding="async" />
                : <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;color:#94a3b8;font-size:14px">Hero image</div>
              }
            </div>
          </div>
        </div>
      </section>

      <!-- THIN NAVY STRIPE -->
      <div class="stats-bar">
        <div class="wrap">
          <div class="stats-inner">
            <div class="stat-message">
              Save up to <span>79% vs Adobe Acrobat Pro</span> — perpetual licence, no subscription, no renewal fees
            </div>
            <div style="display:flex;gap:20px;flex-wrap:wrap;justify-content:center;margin-top:4px">
              <div style="font-size:13px;color:#94a3b8">✓ <span style="color:white;font-weight:600">40 years</span> in market</div>
              <div style="font-size:13px;color:#94a3b8">✓ <span style="color:white;font-weight:600">15M+ users</span> worldwide</div>
              <div style="font-size:13px;color:#94a3b8">✓ <span style="color:white;font-weight:600">15-day</span> free trial</div>
              <div style="font-size:13px;color:#94a3b8">✓ <span style="color:white;font-weight:600">A$261</span> one-time</div>
            </div>
          </div>
        </div>
      </div>

      <section id="benefits">
        <div class="wrap">
          <div class="sh">
            <h2>Why Australian organisations choose Power PDF</h2>
            <p>Enterprise-grade PDF capability — without the Adobe Acrobat price tag.</p>
          </div>
          <div class="grid">
            {site.benefits?.map((b) => (
              <div class="benefit-card c6">
                <div class="card-icon">{b.icon}</div>
                <h3>{b.title}</h3>
                <p>{b.body}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="pricing" class="neutral-bg">
        <div class="wrap">
          <div class="sh">
            <h2>Simple, transparent pricing</h2>
            <p>One-time purchase. Own it forever. No subscriptions, no renewals.</p>
          </div>
          <div class="grid">
            {site.pricing?.map((p) => (
              <div class={`pricing-card c4${p.highlight ? " highlight" : ""}`}>
                {p.highlight && <div class="pricing-badge">Most popular</div>}
                <div class="pricing-name">{p.name}</div>
                <div class="pricing-platform">{p.platform}</div>
                <div class="pricing-price">{p.price}</div>
                <div class="pricing-note">{p.priceNote}</div>
                <ul class="pricing-features">
                  {p.features?.map((f) => <li>{f}</li>)}
                </ul>
                <a class="btn btn-primary" href="#final-cta" style="text-align:center">{site.primaryCTA.text}</a>
              </div>
            ))}
          </div>
          <div class="card" style="margin-top:32px">
            <h3 style="margin:0 0 4px">{site.tco?.heading}</h3>
            <p style="color:#475569;font-size:14px;margin:0 0 4px">Switch now and keep the savings every year.</p>
            <table class="tco-table">
              <thead>
                <tr>
                  <th>Product</th>
                  <th>3-year total (10 users)</th>
                  <th>Licence type</th>
                </tr>
              </thead>
              <tbody>
                {site.tco?.rows?.map((r, i) => (
                  <tr class={i === 0 ? "winner" : ""}>
                    <td>{r.product}</td>
                    <td>{r.cost}</td>
                    <td>{r.type}</td>
                  </tr>
                ))}
              </tbody>
            </table>
            <p class="tco-note">{site.tco?.note}</p>
          </div>
        </div>
      </section>

      <section id="about">
        <div class="wrap">
          <div class="grid">
            <div class="card c7">
              {imgSrc("about-banner") && <div class="card-img"><img src={imgSrc("about-banner")} alt={imgAlt("about-banner")} loading="lazy" decoding="async" /></div>}
              <h3>Local expertise. Enterprise results.</h3>
              <p>Voice Recognition Australia has been deploying enterprise document software across Australian government, legal, and corporate environments for 25 years. We provide local onboarding, training, and ongoing support — not just a licence key.</p>
              <div style="margin-top:16px;display:flex;flex-wrap:wrap;gap:8px">
                {site.proofPoints?.map((p) => (
                  <div style="background:#f1f5f9;border-radius:999px;padding:6px 14px;font-size:13px;font-weight:600;color:#334155">✓ {p}</div>
                ))}
              </div>
            </div>
            <div class="card c5" style="background:#1a2f5e;color:white;border-color:#1a2f5e">
              <h3 style="color:white;margin:0 0 16px">Power PDF editions</h3>
              <div class="edition">
                <div class="edition-name">Standard — $188 AUD</div>
                <div class="edition-desc">Individual users. Create, edit, convert, sign. Perpetual licence for Windows.</div>
              </div>
              <div class="edition">
                <div class="edition-name">Advanced — $261 AUD ★</div>
                <div class="edition-desc">Business users. Adds redaction, Bates numbering, batch processing, e-signatures, SharePoint integration.</div>
              </div>
              <div class="edition">
                <div class="edition-name">Mac — $188 AUD</div>
                <div class="edition-desc">Full PDF editing for macOS 10.15 to 14. Native Apple Silicon support.</div>
              </div>
              <div class="edition">
                <div class="edition-name">Business SaaS</div>
                <div class="edition-desc">Enterprise volume. Cloud editor, Teams integration, centralised management. Contact us for pricing.</div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="how-it-works" class="neutral-bg">
        <div class="wrap">
          <div class="sh">
            <h2>How it works</h2>
            <p>From enquiry to deployment — we handle everything locally.</p>
          </div>
          <div class="grid">
            {site.steps?.map((s, i) => (
              <div class="card c4">
                <div class="step-num">{i + 1}</div>
                <h3>{s.title}</h3>
                <p>{s.text}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="features">
        <div class="wrap">
          <div class="sh">
            <h2>Key features</h2>
            <p>Everything your team needs to work with documents securely and efficiently.</p>
          </div>
          <div class="grid">
            {site.features?.map((f) => (
              <div class="card c6">
                {imgSrc(f.key) && <div class="card-img"><img src={imgSrc(f.key)} alt={imgAlt(f.key)} loading="lazy" decoding="async" /></div>}
                <div class="card-icon">{f.icon}</div>
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="faq" class="neutral-bg">
        <div class="wrap">
          <div class="sh">
            <h2>Frequently asked questions</h2>
          </div>
          <div class="grid">
            {site.faqs?.map((f) => (
              <div class="card c6">
                <h3>{f.q}</h3>
                <p>{f.a}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="final-cta" class="dark-bg">
        <div class="wrap">
          <div class="grid">
            <div class="c7">
              {imgSrc("cta-banner") && <div style="border-radius:16px;overflow:hidden;aspect-ratio:16/9;margin-bottom:24px"><img src={imgSrc("cta-banner")} alt={imgAlt("cta-banner")} loading="lazy" style="width:100%;height:100%;object-fit:cover" /></div>}
              <h2 style="color:white;font-size:28px;margin:0 0 12px">Ready to switch from Adobe Acrobat?</h2>
              <p style="color:#94a3b8;margin:0 0 20px">Tell us about your organisation and we'll respond within one business day with a tailored proposal — licensing options, volume pricing, and a free 15-day trial.</p>
              <ul style="color:#94a3b8;margin:0;padding-left:20px;line-height:2.2;font-size:15px">
                <li>Organisation name and sector</li>
                <li>Number of users and platform (Windows / Mac)</li>
                <li>Current PDF solution and pain points</li>
                <li>Procurement requirements or constraints</li>
              </ul>
            </div>
            <div class="c5">
              <div class="formbox">
                <div style="font-weight:800;font-size:20px;color:#0f172a">Get in touch</div>
                <div style="color:#475569;font-size:15px">Local Australian support. Fast response.</div>
                <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:10px;padding:16px;color:#94a3b8;font-size:13px">
                  Replace this with your ActiveCampaign or HubSpot form embed.
                </div>
                <a class="btn btn-primary btn-lg" href="mailto:info@voicerecognition.com.au" style="text-align:center">{site.primaryCTA.text}</a>
                <a class="btn btn-secondary btn-lg" href="#trial" style="text-align:center">{site.secondaryCTA.text}</a>
              </div>
            </div>
          </div>
        </div>
      </section>

    </main>

    <footer>
      <div class="wrap">
        <div class="footer-inner">
          <div>© {year} {site.siteName} — A Voice Recognition Australia service</div>
          <div class="footer-links">
            {site.footerLinks?.map((l) => <a href={l.url}>{l.label}</a>)}
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>
